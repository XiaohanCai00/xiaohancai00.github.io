@article{CLZ24,
  title={An area growth estimate of the Liouville equation},
  author={Cai, Xiaohan and Lai, Mijia and Zhang, Chilin},
  journal={arXiv preprint arXiv:2409.19327},
  year={2024},
  arxiv = {2409.19327},
  bibtex_show = {true},
  selected = {true},
  abstract = {We establish an area growth estimate for solutions that are bounded from above of the Liouville equation
    \begin{equation}
        \Delta u+K e^{2u}=0
    \end{equation}
    with a positive pinched curvature $0<\lambda\leq K\leq\Lambda$. 
  As an application, we provide a new proof of Eremenko-Gui-Li-Xu's result (Comm. Anal. Geom., 2025).
  We also classify solutions with an upper bound in the half plane with the boundary having constant geodesic curvature.}
}

